# Gemini configuration
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# App metadata
APP_URL="https://your-cloud-run-service-url"
APPLET_ID="your-applet-id"
NEXT_PUBLIC_APPLET_ID="your-applet-id"

# Datadog RUM configuration
# These values are browser-safe and are baked into the Next.js client bundle at build time.
NEXT_PUBLIC_DATADOG_CLIENT_TOKEN="pub_..."
NEXT_PUBLIC_DATADOG_APPLICATION_ID="app_..."
NEXT_PUBLIC_DATADOG_SITE="datadoghq.com"
NEXT_PUBLIC_DATADOG_SERVICE="box-box-bits-ai"
NEXT_PUBLIC_DATADOG_ENV="production"

# Google Cloud deployment configuration
GCP_PROJECT_ID="your-gcp-project-id"
GCP_REGION="asia-southeast1"
CR_SERVICE_NAME="box-box-bits-ai"
ARTIFACT_REPO="cloud-run-source-deploy"

# Datadog server-side configuration
DD_ENV="prod"
DD_SERVICE="box-box-bits-ai"
DD_API_KEY="dd_api_key"
DD_APP_KEY="dd_app_key"
DD_SITE="datadoghq.com"
DD_LOGS_ENABLED="true"
DD_PROFILING_ENABLED="true"
DD_LLMOBS_ML_APP="box-box-bits-ai"

# Optional Datadog RUM aliases for external tooling or future server-side config rendering.
DD_RUM_APP_ID="app_..."
DD_RUM_CLIENT_TOKEN="pub_..."
