# Gemini configuration
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ── Demo mode ────────────────────────────────────────────────────────────────
# Set to "true" to enable high-latency demo mode for observability showcases.
# Switches model → gemini-3.1-pro-preview, thinkingBudget → 24576 (max),
# and prepends a verbose chain-of-thought system prompt on all LLM calls.
# Remove or set to any other value to revert to normal production settings.
DEMO_HIGH_LATENCY="false"

# Act 3 — inject NullPointerException on THB currency handler in merch checkout.
# Toggle without redeploy: ./scripts/demo-pipeline.sh --error-inject-on / --error-inject-off
DEMO_ERROR_INJECT="false"

# ── Data pipeline (Redpanda + BigQuery) ──────────────────────────────────────
# Redpanda broker(s) — LoadBalancer external IP from GKE.
# Get IP after Redpanda deploy: kubectl get svc redpanda-kafka-lb -n data-pipeline
REDPANDA_BROKERS="<REDPANDA_LB_IP>:9092"

# BigQuery service account key (JSON string or file path).
# Set BQ_SA_KEY_JSON to the contents of the SA key JSON for Cloud Run.
# Or set GOOGLE_APPLICATION_CREDENTIALS to the path of the SA key file for local dev.
BQ_PROJECT="datadog-ese-sandbox"
BQ_SA_KEY_JSON=""
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/sa-key.json"

# Enable Datadog Data Streams Monitoring on Kafka producer/consumer paths.
DD_DATA_STREAMS_ENABLED="true"

# App metadata
APP_URL="https://your-cloud-run-service-url"
APPLET_ID="your-applet-id"
NEXT_PUBLIC_APPLET_ID="your-applet-id"

# Datadog RUM configuration
# These values are browser-safe and are baked into the Next.js client bundle at build time.
NEXT_PUBLIC_DATADOG_CLIENT_TOKEN="pub_..."
NEXT_PUBLIC_DATADOG_APPLICATION_ID="app_..."
NEXT_PUBLIC_DATADOG_SITE="datadoghq.com"
NEXT_PUBLIC_DATADOG_SERVICE="box-box-bits-ai"
NEXT_PUBLIC_DATADOG_ENV="production"

# Google Cloud deployment configuration
GCP_PROJECT_ID="your-gcp-project-id"
GCP_REGION="asia-southeast1"
CR_SERVICE_NAME="box-box-bits-ai"
ARTIFACT_REPO="cloud-run-source-deploy"

# Datadog server-side configuration
DD_ENV="prod"
DD_SERVICE="box-box-bits-ai"
DD_API_KEY="dd_api_key"
DD_APP_KEY="dd_app_key"
DD_SITE="datadoghq.com"
DD_LOGS_ENABLED="true"
DD_PROFILING_ENABLED="true"
DD_LLMOBS_ML_APP="box-box-bits-ai"

# Optional Datadog RUM aliases for external tooling or future server-side config rendering.
DD_RUM_APP_ID="app_..."
DD_RUM_CLIENT_TOKEN="pub_..."
